# Ollama data (models ~243 GB)
ollama/

# Open WebUI data (DB, uploads, cache, vector_db)
openwebui/

# Monitoring SQLite DB (wird live generiert, nicht versioniert)
monitoring/monitor.db
monitoring/monitor.db-wal
monitoring/monitor.db-shm

# Per-host monitoring config (a real config.toml is created from
# config.example.toml on first install — see monitoring/install.sh).
# Per-Host Monitoring-Config (echte config.toml wird beim ersten install
# aus config.example.toml erzeugt — siehe monitoring/install.sh).
monitoring/config.toml

# Generated dashboard HTML (regenerated on every page load).
# Generiertes Dashboard HTML (bei jedem Aufruf neu erzeugt).
monitoring/dashboard.html
monitoring/api/dashboard.html

# Stall-Stack-Dumps (live generiert, 30d Retention)
monitoring/stalls/

# Python bytecode
monitoring/__pycache__/
monitoring/**/__pycache__/

# Environment (kann Secrets enthalten)
.env

# Claude Code Session-Daten
.claude/
