# Copy to .env and fill in values for your host.
# Cp nach .env und Werte fuer deinen Host eintragen.

# Where Docker volumes live on the host.
# Wo die Docker-Volumes auf dem Host liegen.
DATA_ROOT=/srv/Container

# IP address(es) the container ports bind to. Use 0.0.0.0 for all interfaces,
# 127.0.0.1 for localhost-only, or a LAN/WLAN IP to expose to the network.
# IP-Adresse(n) auf die Container-Ports binden. 0.0.0.0 = alle Interfaces,
# 127.0.0.1 = nur lokal, oder eine LAN/WLAN-IP zur Netzwerk-Freigabe.
BIND_IP=127.0.0.1
BIND_IP_WLAN=127.0.0.1

# External port for the Open WebUI frontend (mapped to container port 8080).
# Externer Port fuers Open WebUI Frontend (auf Container-Port 8080 gemappt).
OPENWEBUI_PORT=3000

# Optional: docker compose project name (keeps containers/networks unique
# across multiple deployments on the same host).
# Optional: docker compose Projektname (haelt Container/Netze eindeutig
# bei mehreren Deployments auf demselben Host).
COMPOSE_PROJECT_NAME=openllm

# Optional: pin Ollama to specific GPU UUID (find via `nvidia-smi -L`).
# Leave empty (or remove) to use NVIDIA_VISIBLE_DEVICES=all.
# Optional: Ollama auf eine bestimmte GPU UUID pinnen (`nvidia-smi -L`).
# Leer lassen (oder entfernen) fuer NVIDIA_VISIBLE_DEVICES=all.
# GPU_UUID=GPU-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
